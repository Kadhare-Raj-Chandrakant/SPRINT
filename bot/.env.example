# ═══════════════════════════════════════════════════════════════════════════
# glint — environment configuration template
#
# Copy this file to `bot/.env` and fill in the values. `BotApplication`
# loads `.env` (from ./, ./bot/, or ../) into system properties at startup,
# so these variables take effect even when running via `mvn spring-boot:run`
# or `docker compose`.
#
# Every key below maps to a real property in the code (see
# bot/src/main/java/com/bot/bot/config/*.java). Required keys are marked
# [REQUIRED]; the bot fails to start if they are empty.
#
# Tip: never commit your real `.env` (it is gitignored). This file is a
# template and is safe to commit.
# ═══════════════════════════════════════════════════════════════════════════

# ── GitHub App [REQUIRED] ──────────────────────────────────────────────────
# glint authenticates as a GitHub App (JWT from the private key -> short-lived
# installation token). See docs/tutorial-getting-started.md for setup.
GITHUB_APP_ID=123456
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxx
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret-from-github-app
# Path to the App's private key (.pem). The file must exist at this path
# relative to the working directory (or absolute). Place it at
# bot/certs/github-app.pem and gitignore keeps it out of the repo.
# NOTE: the code default is certs/private-key.pem, but the repo convention
# (tutorial + certs/.gitignore) is certs/github-app.pem — set it explicitly.
GITHUB_PRIVATE_KEY_PATH=certs/github-app.pem
# GitHub API base URL. Only change for GitHub Enterprise Server.
GITHUB_API_URL=https://api.github.com

# ── LLM review provider [REQUIRED if LLM_ENABLED=true] ────────────────────
# glint reviews diff chunks with an LLM. The provider list lives in
# bot/src/main/resources/application.yaml (llm.providers); these env vars
# seed the FIRST provider and let you flip providers without editing YAML.
#
# Supported provider-type values (application.yaml llm.providers[].provider-type):
#   openai-compatible  -> any OpenAI /chat/completions-compatible endpoint
#   nvidia-nim         -> NVIDIA NIM (self-hosted or integrate.api.nvidia.com)
#   ollama             -> local Ollama server
LLM_PROVIDER_TYPE=openai-compatible
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
# API key sent as `Authorization: Bearer <LLM_API_KEY>`. Ollama needs none
# (leave empty). This maps to llm.providers[0].api-key in application.yaml.
LLM_API_KEY=sk-your-key-here
# Master switch for the LLM review path. Set false to run heuristics-only.
LLM_ENABLED=true
# Per-request timeout (seconds) applied to every provider.
LLM_TIMEOUT_SECONDS=60

# ── Application / one-click actions ───────────────────────────────────────
# Random secret (>= 32 chars) used to sign single-use action tokens.
# Without it, Approve/Request-changes/Close buttons are not rendered.
APP_ACTION_SECRET=replace-with-a-random-32-char-secret
# Public base URL of the running app. Used to build dashboard action links
# (e.g. https://your-ngrok-url.ngrok-free.dev). Use http://localhost:8080
# for purely local testing.
APP_BASE_URL=http://localhost:8080

# ── Triaging behavior toggles (optional, defaults shown) ──────────────────
HEURISTICS_ENABLED=true
AUTO_APPROVE=false
INLINE_COMMENTS=true
REVIEW_SUMMARY_ENABLED=true

# ── HTTP server ───────────────────────────────────────────────────────────
# Port the webhook/dashboard listens on.
PORT=8080

# ── PostgreSQL (DATABASE_URL, or individual parts) ────────────────────────
# Used by spring.datasource. Provide DATABASE_URL, or the three parts below.
DATABASE_URL=jdbc:postgresql://localhost:5432/pr_triage
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# Optional connection-pool tuning (spring.datasource.hikari.*).
DATABASE_POOL_SIZE=10
DATABASE_MIN_IDLE=2

# ── Mail (optional, provider-agnostic SMTP) ───────────────────────────────
# When enabled, glint sends a daily digest plus an immediate alert for
# RED-tier / security-flagged PRs. Gmail :587 needs STARTTLS (handled in code).
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
# Spring cron (6 fields) for the daily digest.
MAIL_DIGEST_CRON=0 0 18 * * *
# Comma-separated default recipient list.
MAIL_MAINTAINERS=you@example.com
